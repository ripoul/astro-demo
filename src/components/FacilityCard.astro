---
import PlaceholderImage from './PlaceholderImage.astro';

interface Props {
  title: string;
  description: string;
  imageLabel: string;
  details?: string[];
}

const { title, description, imageLabel, details = [] } = Astro.props;
---

<article class="facility-card">
  <PlaceholderImage label={imageLabel} ratio="4 / 3" />
  <div class="facility-card__body">
    <h3>{title}</h3>
    <p>{description}</p>
    {
      details.length > 0 && (
        <ul class="facility-card__details">
          {details.map((detail) => (
            <li>{detail}</li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .facility-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
  }

  .facility-card__body {
    padding: 1.5rem;
  }

  .facility-card p {
    color: var(--color-text-muted);
  }

  .facility-card__details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-size: 0.92rem;
  }

  .facility-card__details li {
    padding-left: 1.1rem;
    position: relative;
  }

  .facility-card__details li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: 700;
  }
</style>
